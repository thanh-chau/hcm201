{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores custom user information like display name and avatar.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "Custom display name" },
        "photoURL": { "type": "string", "description": "Custom avatar URL" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat history.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["text", "role", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "User chat history"
    }
  }
}
