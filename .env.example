# Copy this file to .env.local, then fill in your own keys.
# Do not commit real API keys.

# OpenAI or OpenAI-compatible LLM gateway.
# Server-side only. Do not prefix these with VITE_.
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.freemodel.dev/v1
OPENAI_LOCAL_RAG_DIRS=knowledge-full,knowledge
OPENAI_LOCAL_RAG_MAX_CHUNKS=4

# Optional OpenAI Vector Store RAG.
# Only used for official OpenAI base URLs that support Responses API file_search.
OPENAI_VECTOR_STORE_IDS=vs_your_vector_store_id_here
OPENAI_FILE_SEARCH_MAX_RESULTS=6

# Legacy vector store fallbacks. Prefer OPENAI_VECTOR_STORE_IDS above.
VITE_HCM_CHAPTER5_VECTOR_STORE_ID=vs_6a0a7ca623c88191bab3a7a57fda092f
VITE_HCM_TEXTBOOK_VECTOR_STORE_ID=vs_6a0a7b17bce88191aa2148a40d6dc6de
VITE_VECTOR_STORE_ID=
VITE_FILE_SEARCH_MAX_RESULTS=6

