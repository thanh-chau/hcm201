rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (required, 1-50 chars)
    //   - photoURL: string (optional, valid URL)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - text: string (required, 1-5000 chars)
    //   - role: string (required, 'user' or 'model')
    //   - timestamp: timestamp (required)
    //   - userId: string (required, matches parent)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.updatedAt is timestamp &&
             (!('photoURL' in data) || data.photoURL == "" || data.photoURL == null || isValidUrl(data.photoURL));
    }

    function isValidMessage(data, userId) {
      return data.keys().hasAll(['text', 'role', 'timestamp', 'userId']) &&
             data.text is string && data.text.size() >= 1 && data.text.size() <= 5000 &&
             data.role in ['user', 'model'] &&
             data.timestamp is timestamp &&
             data.userId == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
